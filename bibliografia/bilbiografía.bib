@misc{zhang_quantum_2026,
	title = {Quantum reinforcement learning-based active flow control},
	url = {http://arxiv.org/abs/2601.17801},
	doi = {10.48550/arXiv.2601.17801},
	abstract = {Active flow control remains a significant challenge due to the high-dimensional, nonlinear nature of fluid dynamics. Quantum machine learning may prove effective in addressing these issues, given that quantum computing possesses superiority over traditional computing in some extend. Thus, this study developed a quantum reinforcement learning (QRL) based active flow control framework, integrating variational quantum circuits (VQCs) with the proximal policy optimization (PPO) algorithm to learn a real time controller. Firstly, we tested the QRL in a CartPole problem. The QRL shows parameter efficiency and enhanced learning capability, indicating VQC acts as promising candidates for advancing RL, particularly in scenarios requiring both computational efficiency and robust performance. The active control of flow past a square circular cylinder at a Reynolds number of 100 was tested via QRL. Our hybrid architecture encodes high-dimensional flow states into a quantum policy network, which generates continuous blowing/suction actions on the cylinder’s surface, and thus suppress the vortex shedding to achieve drag reduction. Numerical simulations demonstrate the QRL successfully reduces the mean drag and attenuates lift oscillations. Flow field analysis confirms that QRL control effectively suppresses large-scale vortex shedding, leading to a narrower, more stable wake compared to the uncontrolled baseline. These results validate the potential of quantum-enhanced learning for tackling complex fluid dynamics problems. The proposed QRL framework establishes a promising blueprint for quantum-AI accelerated solutions in aerospace design, energy-efficient turbomachinery, and other applications involving sophisticated fluid-structure interactions.},
	language = {en},
	urldate = {2026-03-22},
	publisher = {arXiv},
	author = {Zhang, Hongfu and Tang, Hui},
	month = jan,
	year = {2026},
	note = {arXiv:2601.17801 [physics]},
	keywords = {Physics - Fluid Dynamics},
	file = {PDF:files/168/Zhang y Tang - 2026 - Quantum reinforcement learning-based active flow control.pdf:application/pdf},
}

@inproceedings{son_q-rlonas_2025,
	address = {Albuquerque, NM, USA},
	title = {Q-{RLONAS}: {Towards} {Efficient} {Quantum} {Neural} {Architecture} {Search}},
	copyright = {https://doi.org/10.15223/policy-029},
	isbn = {979-8-3315-5736-2},
	shorttitle = {Q-{RLONAS}},
	url = {https://ieeexplore.ieee.org/document/11250292/},
	doi = {10.1109/QCE65121.2025.00193},
	abstract = {Quantum neural architecture search aims to automate the design of parameterized quantum circuits (PQCs) within quantum neural networks (QNNs), where learning performance is highly sensitive to the placement and type of quantum gates. However, applying traditional NAS techniques to quantum circuits presents significant challenges, including barren plateaus, noise accumulation, device-specific constraints, and the high computational cost of independently evaluating all candidate architectures. To address these limitations, this paper proposes Q-RLONAS, a two-stage quantum NAS framework that integrates deep reinforcement learning (DRL) with one-shot NAS to efficiently explore and optimize PQC structures. In the Stage \#1, DRL determines the optimal gate placement by leveraging a reward function that considers performance, noise, barren plateaus, and hardware constraints. In the Stage \#2, a one-shot NAS method is employed to select effective quantum gate types using weight sharing within a supernet, significantly reducing training overhead. Experimental results on the mini-MNIST dataset demonstrate that Q-RLONAS achieves high accuracy while satisfying gate placement constraints, outperforming existing approaches in terms of efficiency for quantum circuit design.},
	language = {en},
	urldate = {2026-03-22},
	booktitle = {2025 {IEEE} {International} {Conference} on {Quantum} {Computing} and {Engineering} ({QCE})},
	publisher = {IEEE},
	author = {Son, Seok Bin and Park, Soohyun},
	month = aug,
	year = {2025},
	pages = {1756--1765},
	file = {PDF:files/169/Son y Park - 2025 - Q-RLONAS Towards Efficient Quantum Neural Architecture Search.pdf:application/pdf},
}

@article{kulshrestha_neural_2025,
	title = {Neural {Architecture} {Search} {Algorithms} for {Quantum} {Autoencoders}},
	volume = {6},
	copyright = {https://creativecommons.org/licenses/by-nc-nd/4.0/},
	issn = {2689-1808},
	url = {https://ieeexplore.ieee.org/document/11184671/},
	doi = {10.1109/TQE.2025.3615886},
	abstract = {The design of quantum circuits is currently driven by the specific objectives of the quantum algorithm in question. This approach thus relies on a significant manual effort by the quantum algorithm designer to design an appropriate circuit for the task. However, this approach cannot scale to more complex quantum algorithms in the future without exponentially increasing the circuit design effort and introducing unwanted inductive biases. Motivated by this observation, we propose to automate the process of circuit design by drawing inspiration from neural architecture search (NAS). In this work, we propose two quantumNAS algorithms that aim to find efficient circuits given a particular quantum task. We choose quantum data compression as our driver quantum task and demonstrate the performance of our algorithms by finding efficient autoencoder designs that outperform baselines on three different tasks: quantum data denoising, classical data compression, and pure quantum data compression. Our results indicate that quantum NAS algorithms can significantly alleviate the manual effort while delivering performant quantum circuits for any given task.},
	language = {en},
	urldate = {2026-03-22},
	journal = {IEEE Trans. Quantum Eng.},
	author = {Kulshrestha, Ankit and Liu, Xiaoyuan and Ushijima-Mwesigwa, Hayato and Safro, Ilya},
	year = {2025},
	pages = {1--17},
	file = {PDF:files/170/Kulshrestha et al. - 2025 - Neural Architecture Search Algorithms for Quantum Autoencoders.pdf:application/pdf},
}

@inproceedings{burugupalli_transferable_2025,
	address = {Raipur, India},
	title = {Transferable {Agentic} {AI} for {Accelerating} {Quantum} {Algorithm} {Discovery}: {Meta}-{Learning} and {AutoML} for {Parameterized} {Quantum} {Circuits}},
	copyright = {https://doi.org/10.15223/policy-029},
	isbn = {979-8-3315-6726-2},
	shorttitle = {Transferable {Agentic} {AI} for {Accelerating} {Quantum} {Algorithm} {Discovery}},
	url = {https://ieeexplore.ieee.org/document/11404979/},
	doi = {10.1109/ISED67359.2025.11404979},
	abstract = {Discovering effective parameterized quantum circuits (PQCs) remains a major obstacle in the noisy intermediatescale quantum (NISQ) era due to barren plateaus, noise sensitivity, and heavy trial-and-error in ansatz selection and initialization. We propose Q-Transfer-Search, a transferable agentic AI framework that unifies meta-learning and automated machine learning (AutoML) to accelerate quantum algorithm discovery. Our method learns reusable parameter priors via meta-learning, enabling fast adaptation to new tasks, while a noise-aware architecture controller proposes PQCs optimized for hardware constraints. A measurement-efficient evaluator based on classical shadows and parameter-shift rules provides low-cost feedback for both inner and outer optimization loops. Evaluations on VQE, QAOA, and quantum machine learning tasks show that Q-Transfer-Search achieves lower energy errors, higher approximation ratios, and improved classification accuracy while reducing circuit evaluations and measurement shots. Compared to state-of-the-art baselines such as QuantumNAS, Meta-VQA, Q-MAML, and MG-Net, our framework consistently improves convergence speed and robustness. These results highlight the promise of agentic AI in enabling scalable, transferable, and resource-efficient quantum algorithm design.},
	language = {en},
	urldate = {2026-03-22},
	booktitle = {2025 13th {International} {Conference} on {Intelligent} {Systems} and {Embedded} {Design} ({ISED})},
	publisher = {IEEE},
	author = {Burugupalli, Satyanarayana},
	month = dec,
	year = {2025},
	pages = {974--979},
	file = {PDF:files/171/Burugupalli - 2025 - Transferable Agentic AI for Accelerating Quantum Algorithm Discovery Meta-Learning and AutoML for P.pdf:application/pdf},
}

@inproceedings{zhu_brief_2022,
	address = {Larissa Greece},
	title = {A {Brief} {Survey} of {Quantum} {Architecture} {Search}},
	isbn = {978-1-4503-9740-7},
	url = {https://dl.acm.org/doi/10.1145/3564982.3564989},
	doi = {10.1145/3564982.3564989},
	abstract = {With the rapid development of quantum computing, the variational quantum algorithms capitalize on the classical optimizer and parametrized quantum circuit to provide outperformance on specific tasks such as combinatorial optimization problems. However, the performance of these hybrid quantum-classical algorithms heavily relies on the design of quantum circuit architecture. Being restricted by the noise of the near-term quantum device, how to trade off the computational power of quantum circuits and the noise of quantum gates is a challenging task for design circuit architecture. In this paper, we give a brief view of the recently proposed methods for quantum architecture search including the differentiable circuit search method, deep reinforcement learning based method, and evolutionary based methods.},
	language = {en},
	urldate = {2026-03-22},
