	file = {PDF:files/79/Xie et al. - 2025 - An Adaptive Weighted Qite-Vqe Algorithm for Combinatorial Optimization Problems.pdf:application/pdf},
}

@article{ruan_divided-qubo-based_2026,
	title = {The {Divided}-{QUBO}-{Based} {Quantum} {Algorithm} for {Optimal} {Wireless} {Link} {Scheduling}},
	volume = {14},
	copyright = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/IEEE.html},
	issn = {2168-6750, 2376-4562},
	url = {https://ieeexplore.ieee.org/document/11244264/},
	doi = {10.1109/TETC.2025.3630066},
	abstract = {Link scheduling in wireless communication aims to minimize interference and maximize channel utilization. When accurate channel state information (CSI) is available, optimal scheduling can be achieved by modeling link interference as a conﬂict graph and solving the weighted maximum independent set problem (WMIS). However, the NP-hard nature of WMIS presents signiﬁcant computational challenges in obtaining high-quality solutions efﬁciently. To tackle this challenge, we ﬁrst propose a divided QUBO model, which formulates the original problem into sub-models within non-overlapping subspaces. Building upon this, we then develop a corresponding algorithm called DQAOA, which further narrows the search space within solution bounds established by classical greedy algorithms and semi-deﬁnite programming. Using a specialized mixing operator (the XY-mixer), the algorithm conﬁnes the evolution to each reduced subspace and runs in parallel. Additionally, an auxiliary Hamiltonian inspired by counter-diabatic driving is introduced into the core evolution equation to accelerate convergence. The experimental results on the IBM Qiskit platform demonstrate that DQAOA outperforms classical methods and other QAOA variants, providing an efﬁcient and reliable solution for optimal link scheduling in wireless networks.},
	language = {en},
	number = {1},
	urldate = {2026-03-17},
	journal = {IEEE Trans. Emerg. Topics Comput.},
	author = {Ruan, Yue and Chen, Pengyue and Yang, Zhongge and Zhao, Wei and Tang, Fengxiao and Liu, Zhi and Kato, Nei},
	month = jan,
	year = {2026},
	pages = {17--29},
	file = {PDF:files/80/Ruan et al. - 2026 - The Divided-QUBO-Based Quantum Algorithm for Optimal Wireless Link Scheduling.pdf:application/pdf},
}

@article{kale_quantum_nodate,
