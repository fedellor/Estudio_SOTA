}

@inproceedings{jarsania_quantum-inspired_2026,
	address = {Las Vegas, NV, USA},
	title = {Quantum-{Inspired} {Algorithms} for {Large}-{Scale} {Data} {Analytics}: {A} {Tensor} {Network} {Approach}},
	copyright = {https://doi.org/10.15223/policy-029},
	isbn = {979-8-3315-9397-1},
	shorttitle = {Quantum-{Inspired} {Algorithms} for {Large}-{Scale} {Data} {Analytics}},
	url = {https://ieeexplore.ieee.org/document/11393744/},
	doi = {10.1109/CCWC67433.2026.11393744},
	abstract = {While full-scale quantum computers remain years away from practical deployment, quantum-inspired algorithms executing on classical hardware have emerged as a promising approach for solving computationally intractable problems in large-scale data analytics. This paper presents a comprehensive framework for applying quantum-inspired tensor network algorithms to complex data problems including high-dimensional clustering, feature selection, and recommendation system matrix factorization. We introduce the Quantum-Inspired Algorithm Library (QIAL), a scalable implementation that seamlessly integrates with Apache Spark and other big data frameworks. Through extensive experimentation on datasets ranging from 1 million to 100 million records, we demonstrate that our approach achieves 2.6x speedup compared to classical algorithms while maintaining superior accuracy (average improvement of 2.1\% across five benchmark datasets) and reduced memory footprint (up to 52\% reduction). Our tensor network-based clustering algorithm shows particular promise for NP-hard combinatorial optimization problems that are currently intractable for conventional big data systems. The proposed framework opens new avenues for practical quantum-inspired computing in enterprisescale data analytics applications.},
	language = {en},
	urldate = {2026-03-22},
	booktitle = {2026 {IEEE} 16th {Annual} {Computing} and {Communication} {Workshop} and {Conference} ({CCWC})},
	publisher = {IEEE},
	author = {Jarsania, Jasmin and Chavda, Chhelabhai},
	month = jan,
	year = {2026},
	pages = {0317--0323},
	file = {PDF:files/161/Jarsania y Chavda - 2026 - Quantum-Inspired Algorithms for Large-Scale Data Analytics A Tensor Network Approach.pdf:application/pdf},
}

@inproceedings{fu_exploiting_2024,
	address = {Seoul, Korea, Republic of},
	title = {Exploiting {A} {Quantum} {Multiple} {Kernel} {Learning} {Approach} {For} {Low}-{Resource} {Spoken} {Command} {Recognition}},
	copyright = {https://doi.org/10.15223/policy-029},
	isbn = {979-8-3503-4485-1},
	url = {https://ieeexplore.ieee.org/document/10448120/},
	doi = {10.1109/ICASSP48485.2024.10448120},
	abstract = {We propose a theoretical analysis of quantum projection learning (QPL) that employs multiple kernels, highlighting its advantages through representation error analysis. Building upon previous studies that utilized a single quantum kernel-based method, we further investigate a quantum projection framework that incorporates multiple Gaussian kernels for low-resource spoken command recognition. Our empirical results align with our theoretical insights, suggesting that methods based on multiple kernels can further enhance the performance of QPL. By leveraging the quantum-to-classical projected output embeddings, we integrate this with a prototypical network for acoustic modeling. When evaluated using Arabic, Chuvash, Irish, and Lithuanian low-resource speech from CommonVoice, our proposed method surpasses the recurrent neural network and single kernel-based classiﬁer baselines by an average of +5.28\%.},
	language = {en},
