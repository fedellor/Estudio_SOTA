@article{kundavaram_quantum_nodate,
	title = {Quantum {Support} {Vector} {Regression} for {High}-{Dimensional} {Data}: {A} {Hybrid} {Quantum}-{Classical} {Approach}},
	abstract = {QSVR is introduced which uses quantum feature mapping and classical optimization to handle highdimensional regression problems. The model uses quantum circuits with angles and special entangled layers to create useful quantum kernels. To process financial time-series and credit card transaction datasets, Principal Component Analysis (PCA) is used to preserve 95\% of the information present in the data. As shown, the results are better than those from classical SVR, with the MSE decreasing from 0.025 to 0.009, MAE from 0.045 to 0.020 and R² score improving from 0.89 to 0.975. The evaluation verifies that the model’s prediction bias is low, errors are consistent throughout and the model works well across datasets. Above 256 qubits, the rate of improvement slows down. Even though QSVR can’t be used with big simulations now, researchers have shown it may be useful for regression in the future. These outcomes highlight that strict circuit design, unbiased benchmarking and fair performance evaluation matter in Noisy Intermediate-Scale Quantum (NISQ) computing.},
	language = {en},
	author = {Kundavaram, RamMohan Reddy and Bandhela, Rahul Reddy and Onteddu, Reddy},
	file = {PDF:files/106/Kundavaram et al. - Quantum Support Vector Regression for High-Dimensional Data A Hybrid Quantum-Classical Approach.pdf:application/pdf},
}

@article{chowdhury_exploring_2025,
	title = {Exploring {Quantum} {Support} {Vector} {Regression} for {Predicting} {Hydrogen} {Storage} {Capacity} of {Nanoporous} {Materials}},
	issn = {2943-9981, 2943-9981},
	url = {https://advanced.onlinelibrary.wiley.com/doi/10.1002/aidi.202500015},
	doi = {10.1002/aidi.202500015},
	abstract = {This study presents a comparative analysis of classical support vector regression (SVR) and quantum support vector regression (QSVR) in predicting hydrogen storage capacities for nanoporous materials, with a focus on metal–organic frameworks (MOFs). Utilizing a comprehensive dataset of 98,694 entries, we explore the efficacy of both methods in handling complex, nonlinear relationships. SVR utilizes polynomial kernels, but QSVR incorporates quantum feature maps and quantum kernels to improve regression in high-dimensional environments. Our analysis, based on seven structural and physical properties of MOFs, reveals that SVR outperforms QSVR, achieving an average root mean squared error (RMSE) of 1.84 compared to QSVR’s 2.11 across 100 experiments. Interestingly, when the feature set is reduced to two key parameters (density and void fraction), both models show improved performance, with QSVR demonstrating competitive accuracy (RMSE of 1.30) relative to SVR (RMSE of 1.10). These findings illuminate both the current limitations and the potential of QSVR in real-world applications, particularly in materials informatics. While classical methods currently maintain an edge in accuracy, the promising performance of QSVR with reduced feature sets suggests significant potential for quantum machine learning approaches. As quantum hardware and algorithms continue to advance, we anticipate enhanced capabilities of QSVR in modeling complex, high-dimensional datasets, potentially revolutionizing predictive modeling in materials science.},
	language = {en},
	urldate = {2026-03-18},
	journal = {adv. intell. discov.},
	author = {Chowdhury, Chandra},
	month = nov,
	year = {2025},
	pages = {e202500015},
	file = {PDF:files/107/Chowdhury - 2025 - Exploring Quantum Support Vector Regression for Predicting Hydrogen Storage Capacity of Nanoporous M.pdf:application/pdf},
}

