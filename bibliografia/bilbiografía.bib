	keywords = {Computational Physics (physics.comp-ph), Disordered Systems and Neural Networks (cond-mat.dis-nn), FOS: Physical sciences, Quantum Physics (quant-ph), Statistical Mechanics (cond-mat.stat-mech)},
	annote = {Other
6 pages plus additional material},
	file = {PDF:files/77/Brodoloni et al. - 2026 - Energy gap of quantum spin glasses a projection quantum Monte Carlo study.pdf:application/pdf},
}

